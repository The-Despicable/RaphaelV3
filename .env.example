# ============================================================
# Raphael 2.0 — Environment Configuration
# ============================================================
# Copy to .env and fill in your keys. NEVER commit .env.
# cp .env.example .env
#
# WARNING: Do not use default/example values in production.
# Run `python3 scripts/validate_env.py` after setup to verify.

# --- API Keys ---
# OpenRouter / OpenAI-compatible fallback (for Ollama-connected models)
OPENAI_API_KEY=
# OmniRoute local proxy (free fallback provider)
OMNIROUTE_BASE=http://localhost:20128/v1
OMNIROUTE_API_KEY=

# --- Cost Control ---
MAX_SPEND_TOKENS=1000000
RAPHAEL_COST_CONTROL=1

# --- Tor Proxy ---
TOR_PROXY=socks5h://tor-proxy:9050
TOR_CONTROL=tor-proxy:9051
TOR_CONTROL_PASS=                     # REQUIRED: set a strong password (min 16 chars)

# --- API Security ---
API_KEY=                              # REQUIRED: min 32-char random key

# --- Phishing ---
GOPHISH_API_KEY=                      # REQUIRED: min 32-char random key
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_PASS=
FROM_ADDR=noreply@example.com

# --- Recon Pipeline ---
SHODAN_API_KEY=
SPIDERFOOT_API_KEY=
SUBFINDER_PATH=

# --- Neo4j ---
NEO4J_USER=neo4j
NEO4J_PASS=                           # REQUIRED: set a strong password (min 16 chars)

# --- Ollama (local proxy for worm models) ---
OPENAI_BASE_URL=http://host.docker.internal:11434/v1
