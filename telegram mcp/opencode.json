{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "opencode-telegram": {
      "command": "python3",
      "args": ["/PATH/TO/opencode-telegram-mcp/mcp_server.py"],
      "env": {
        "TELEGRAM_TOKEN": "YOUR_BOT_TOKEN",
        "TELEGRAM_CHAT_ID": "YOUR_CHAT_ID",
        "WORK_DIR": "/home/YOUR_USERNAME"
      },
      "enabled": true
    }
  }
}
