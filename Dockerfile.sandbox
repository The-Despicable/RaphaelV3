FROM python:3.12-slim

RUN apt-get update -qq && apt-get install -y -qq \
    nmap \
    curl \
    wget \
    dnsutils \
    netcat-openbsd \
    git \
    jq \
    ca-certificates \
    openssl \
    ssh \
    && rm -rf /var/lib/apt/lists/*

RUN pip3 install --no-cache-dir \
    sqlmap \
    requests \
    urllib3 \
    aiohttp

RUN wget -q https://github.com/projectdiscovery/nuclei/releases/latest/download/nuclei_3.3.9_linux_amd64.zip -O /tmp/nuclei.zip \
    && unzip -q /tmp/nuclei.zip -d /usr/local/bin/ \
    && rm /tmp/nuclei.zip \
    || echo "nuclei binary download skipped (arm64 fallback)" \
    && wget -q https://github.com/projectdiscovery/httpx/releases/latest/download/httpx_1.6.10_linux_amd64.zip -O /tmp/httpx.zip \
    && unzip -q /tmp/httpx.zip -d /usr/local/bin/ \
    && rm /tmp/httpx.zip \
    || echo "httpx binary download skipped"

RUN mkdir -p /tools /data /workspace

WORKDIR /workspace

CMD ["tail", "-f", "/dev/null"]
